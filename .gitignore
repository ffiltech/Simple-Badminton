# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.keystore
credentials.json

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# typescript
*.tsbuildinfo

# generated native folders
/ios

# Android - exclude secrets and local machine paths, but NOT the source
# (F-Droid builds from source in android/)
android/local.properties
android/.gradle/
android/app/debug.keystore
android/app/.cxx/
android/build/
android/app/build/
android/.kotlin/

# Keystore / signing secrets (root level)
release.keystore
keystore.properties
